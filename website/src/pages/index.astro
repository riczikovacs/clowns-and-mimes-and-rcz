---
const title = 'Clowns and Mimes, on Miscellaneous Topological Spaces... IN THE DARK';
const githubUrl = 'https://github.com/sean-reid/clowns-and-mimes';
const releasesApi = 'https://api.github.com/repos/sean-reid/clowns-and-mimes/releases/latest';
const base = import.meta.env.BASE_URL;
const mimeAvatar = `${base}avatars/mime.png`;
const clownAvatar = `${base}avatars/clown.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    <title>{title}</title>
    <meta
      name="description"
      content="A team tag game played on a dimly lit labyrinth that wraps in unusual ways."
    />
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="Tag every opponent before they tag you. The arena might be a sphere, a torus, or a Klein bottle."
    />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Crect width='16' height='16' fill='%230c0c0e'/%3E%3Ccircle cx='5' cy='8' r='3.4' fill='%23f5f5f5'/%3E%3Ccircle cx='11' cy='8' r='3.4' fill='%23e63946'/%3E%3C/svg%3E"
    />
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Bungee+Shade&family=Comic+Neue:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        color-scheme: dark;
        --ink: #fffceb;
        --paper: #160a1f;
        --clown: #ff3855;
        --clown-soft: #ffd0a8;
        --mime: #ffffff;
        --bow: #38c2ff;
        --candy: #ffd400;
        --accent: #ff8be0;
        --panel: rgba(255, 255, 230, 0.05);
        --border: rgba(255, 255, 230, 0.18);
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        font-family: 'Comic Neue', 'Comic Sans MS', 'Chalkboard SE', cursive;
        font-size: 1.05rem;
        line-height: 1.55;
        color: var(--ink);
        background-color: var(--paper);
        background-image:
          radial-gradient(circle at 22% 18%, rgba(255, 56, 85, 0.35) 0, transparent 28%),
          radial-gradient(circle at 78% 24%, rgba(56, 194, 255, 0.32) 0, transparent 30%),
          radial-gradient(circle at 50% 90%, rgba(255, 212, 0, 0.25) 0, transparent 28%),
          radial-gradient(rgba(255, 255, 255, 0.18) 1.2px, transparent 1.2px),
          radial-gradient(rgba(255, 255, 255, 0.10) 1.2px, transparent 1.2px);
        background-size:
          auto,
          auto,
          auto,
          36px 36px,
          36px 36px;
        background-position:
          0 0,
          0 0,
          0 0,
          0 0,
          18px 18px;
        overflow-x: hidden;
      }
      header, section, footer {
        max-width: 980px;
        margin: 0 auto;
        padding: 0 1.25rem;
      }
      header {
        padding-top: 3rem;
        padding-bottom: 1.5rem;
        text-align: center;
        position: relative;
      }
      .stripes {
        position: absolute;
        inset: 0;
        pointer-events: none;
        opacity: 0.07;
        background: repeating-linear-gradient(
          45deg,
          var(--ink) 0 6px,
          transparent 6px 22px
        );
      }
      h1 {
        font-family: 'Bungee Shade', 'Impact', 'Comic Sans MS', cursive;
        font-size: clamp(2rem, 6vw, 4rem);
        line-height: 1.05;
        margin: 0 0 0.75rem;
        letter-spacing: 0.02em;
        text-shadow:
          3px 3px 0 var(--clown),
          -2px 4px 0 var(--bow),
          0 0 24px rgba(255, 212, 0, 0.45);
        transform: rotate(-1.5deg);
        animation: wiggle 5.5s ease-in-out infinite;
      }
      h1 .accent { color: var(--candy); display: inline-block; animation: bounce 2.4s ease-in-out infinite; }
      .lede {
        max-width: 60ch;
        margin: 0 auto;
        color: var(--clown-soft);
        font-size: clamp(1.05rem, 1.6vw, 1.25rem);
        font-weight: 700;
      }
      .heads {
        display: flex;
        gap: 1.5rem;
        justify-content: center;
        align-items: flex-end;
        margin: 1.8rem 0 0.4rem;
        position: relative;
      }
      .head {
        width: clamp(100px, 16vw, 150px);
        height: clamp(130px, 22vw, 200px);
        border-radius: 50%;
        object-fit: cover;
        object-position: center 28%;
        border: 5px solid var(--candy);
        box-shadow:
          0 0 0 4px var(--paper),
          0 0 0 9px var(--clown),
          0 12px 0 rgba(0, 0, 0, 0.45);
        filter: contrast(1.05);
      }
      .head.mime {
        border-color: var(--bow);
        box-shadow:
          0 0 0 4px var(--paper),
          0 0 0 9px var(--mime),
          0 12px 0 rgba(0, 0, 0, 0.45);
        animation: bobLeft 3.4s ease-in-out infinite;
      }
      .head.clown {
        animation: bobRight 3.4s ease-in-out infinite;
      }
      .downloads {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
        gap: 1rem;
        margin: 1.2rem 0 1.6rem;
      }
      .download {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        padding: 1rem 1.1rem;
        background: var(--panel);
        border: 3px dashed var(--border);
        border-radius: 1.2rem;
        text-decoration: none;
        color: var(--ink);
        font-weight: 700;
        transform: rotate(var(--tilt, 0deg));
        transition: transform 120ms ease, border-color 120ms ease, box-shadow 120ms ease;
      }
      .download:nth-child(1) { --tilt: -1.4deg; }
      .download:nth-child(2) { --tilt: 1.2deg; }
      .download:nth-child(3) { --tilt: -0.8deg; }
      .download:hover {
        transform: rotate(var(--tilt)) scale(1.04) translateY(-3px);
        border-color: var(--candy);
        box-shadow: 6px 6px 0 var(--clown);
      }
      .download[data-recommended='true'] {
        border-style: solid;
        border-color: var(--candy);
        box-shadow: 4px 4px 0 var(--bow);
      }
      .download .platform {
        font-family: 'Bungee Shade', 'Impact', cursive;
        font-size: 1.2rem;
        color: var(--candy);
        letter-spacing: 0.04em;
      }
      .download .file { color: var(--clown-soft); font-size: 0.95rem; }
      h2 {
        font-family: 'Bungee Shade', 'Impact', cursive;
        margin: 3rem 0 0.75rem;
        font-size: clamp(1.6rem, 3.5vw, 2.4rem);
        color: var(--candy);
        transform: rotate(-1deg);
        text-shadow: 3px 3px 0 var(--clown);
      }
      h2::after {
        content: ' !';
        color: var(--bow);
      }
      .rules {
        display: grid;
        gap: 0.6rem;
        padding-left: 1.4rem;
        font-size: 1.1rem;
      }
      .rules li::marker { color: var(--clown); font-weight: 700; }
      .rules li strong {
        background: var(--candy);
        color: var(--paper);
        padding: 0 0.4rem;
        border-radius: 0.4rem;
        font-family: 'Bungee Shade', 'Impact', cursive;
        letter-spacing: 0.02em;
      }
      .topologies {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1.1rem;
        margin: 1rem 0;
      }
      .topology {
        padding: 1rem;
        background: var(--panel);
        border: 3px solid var(--border);
        border-radius: 1.2rem;
        transform: rotate(var(--tilt, 0deg));
        transition: transform 200ms ease, box-shadow 200ms ease;
      }
      .topology:nth-child(1) { --tilt: -1.2deg; }
      .topology:nth-child(2) { --tilt: 1deg; }
      .topology:nth-child(3) { --tilt: -0.8deg; }
      .topology:nth-child(4) { --tilt: 1.6deg; }
      .topology:hover {
        transform: rotate(0deg) scale(1.03);
        box-shadow: 6px 6px 0 var(--bow);
      }
      .topology svg {
        width: 100%;
        height: 110px;
        display: block;
        margin-bottom: 0.6rem;
        color: var(--candy);
      }
      .topology h3 {
        font-family: 'Bungee Shade', 'Impact', cursive;
        margin: 0 0 0.25rem;
        font-size: 1.2rem;
        color: var(--mime);
      }
      .topology p { margin: 0; color: var(--clown-soft); font-size: 0.98rem; }
      footer {
        padding: 3rem 1.25rem 4rem;
        color: var(--clown-soft);
        font-size: 1rem;
        text-align: center;
      }
      footer a { color: var(--candy); }
      .honk {
        display: inline-block;
        background: var(--clown);
        color: var(--mime);
        padding: 0.2rem 0.6rem;
        border-radius: 0.5rem;
        font-family: 'Bungee Shade', 'Impact', cursive;
        transform: rotate(-3deg);
        margin: 0 0.2rem;
      }
      .shh {
        display: inline-block;
        background: var(--mime);
        color: var(--paper);
        padding: 0.2rem 0.6rem;
        border-radius: 0.5rem;
        font-family: 'Bungee Shade', 'Impact', cursive;
        transform: rotate(2deg);
        margin: 0 0.2rem;
      }
      .confetti {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: -1;
      }
      .confetti span {
        position: absolute;
        width: 8px;
        height: 14px;
        opacity: 0.7;
        animation: fall linear infinite;
      }
      @keyframes wiggle {
        0%, 100% { transform: rotate(-1.5deg); }
        25% { transform: rotate(1.5deg) translateY(-2px); }
        50% { transform: rotate(-2deg); }
        75% { transform: rotate(1deg) translateY(1px); }
      }
      @keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-8px) rotate(6deg); }
      }
      @keyframes bobLeft {
        0%, 100% { transform: translateY(0) rotate(-3deg); }
        50% { transform: translateY(-6px) rotate(-6deg); }
      }
      @keyframes bobRight {
        0%, 100% { transform: translateY(0) rotate(4deg); }
        50% { transform: translateY(-8px) rotate(8deg); }
      }
      @keyframes fall {
        from { transform: translateY(-10vh) rotate(0deg); }
        to { transform: translateY(110vh) rotate(720deg); }
      }
      @media (prefers-reduced-motion: reduce) {
        h1, h1 .accent, .head.mime, .head.clown, .confetti span {
          animation: none !important;
        }
        .topology, .download { transform: none !important; }
      }
      @media (max-width: 480px) {
        header { padding-top: 1.8rem; }
        .heads { gap: 0.6rem; }
      }
    </style>
  </head>
  <body>
    <div class="confetti" aria-hidden="true" id="confetti"></div>
    <header>
      <div class="stripes" aria-hidden="true"></div>
      <div class="heads">
        <img class="head mime" src={mimeAvatar} alt="Mime portrait" width="150" height="200" />
        <img class="head clown" src={clownAvatar} alt="Clown portrait" width="150" height="200" />
      </div>
      <h1>
        CLOWNS &amp; MIMES <span class="accent">!!</span><br />
        on MISCELLANEOUS TOPOLOGICAL SPACES<br />
        <span class="accent">...IN THE DARK</span>
      </h1>
      <p class="lede">
        Team tag in a dim labyrinth. Sometimes a torus. Sometimes a Klein bottle. Sometimes a sphere.
        Often confusing. Always loud. <span class="honk">HONK</span> meets <span class="shh">shh</span>.
      </p>
    </header>

    <section aria-labelledby="download">
      <h2 id="download">Download</h2>
      <div class="downloads">
        <a id="dl-windows" class="download" href={`${githubUrl}/releases/latest`}>
          <span class="platform">Windows</span>
          <span class="file" id="dl-windows-file">latest .exe</span>
        </a>
        <a id="dl-macos" class="download" href={`${githubUrl}/releases/latest`}>
          <span class="platform">macOS</span>
          <span class="file" id="dl-macos-file">latest .dmg</span>
        </a>
        <a id="dl-linux" class="download" href={`${githubUrl}/releases/latest`}>
          <span class="platform">Linux</span>
          <span class="file" id="dl-linux-file">latest AppImage</span>
        </a>
      </div>
    </section>

    <section aria-labelledby="how">
      <h2 id="how">How to play</h2>
      <ol class="rules">
        <li>Pick <strong>HOST</strong>, <strong>CODE</strong>, or <strong>STRANGERS</strong> from the main menu.</li>
        <li>Everyone spawns in the center square. Sixty seconds to wander before tags count.</li>
        <li>Turns alternate between the mime team and the clown team. Tag opponents during your turn to freeze them solid.</li>
        <li>Touch a frozen teammate to thaw them.</li>
        <li>Freeze every opponent and bask in the maniacal laugh. Get frozen last and hear the womp womp.</li>
      </ol>
    </section>

    <section aria-labelledby="topology">
      <h2 id="topology">Topologies</h2>
      <p style="max-width: 60ch; color: var(--clown-soft);">
        The arena is one of these. Host picks in private games. Strangers get random.
      </p>
      <div class="topologies">
        <article class="topology">
          <svg viewBox="0 0 160 120" aria-hidden="true">
            <g fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" stroke-linecap="round">
              <path d="M 30 78 L 96 50 L 138 60 L 70 92 Z" />
              <path d="M 50 70 L 122 56" opacity="0.55" />
              <path d="M 70 62 L 132 71" opacity="0.55" />
              <path d="M 90 54 L 120 84" opacity="0.55" />
              <path d="M 60 87 L 113 47" opacity="0.55" stroke-dasharray="3 3" />
            </g>
          </svg>
          <h3>Plane</h3>
          <p>Finite square arena. Hard walls at the edges.</p>
        </article>
        <article class="topology">
          <svg viewBox="0 0 160 120" aria-hidden="true">
            <g fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" stroke-linecap="round">
              <ellipse cx="80" cy="60" rx="60" ry="32" />
              <path d="M 32 60 Q 80 36 128 60" />
              <path d="M 40 60 Q 80 78 120 60" stroke-dasharray="3 3" />
              <ellipse cx="80" cy="60" rx="20" ry="8" />
              <path d="M 50 41 Q 50 60 50 79" opacity="0.55" stroke-dasharray="3 3" />
              <path d="M 110 41 Q 110 60 110 79" opacity="0.55" stroke-dasharray="3 3" />
              <path d="M 80 28 Q 80 60 80 92" opacity="0.55" stroke-dasharray="3 3" />
            </g>
          </svg>
          <h3>Torus</h3>
          <p>Both axes wrap. Walk off one side, come out the opposite.</p>
        </article>
        <article class="topology">
          <svg viewBox="0 0 160 120" aria-hidden="true">
            <g fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" stroke-linecap="round">
              <path d="M 38 96 C 18 96 18 60 42 60 C 64 60 70 78 88 78 C 110 78 120 56 120 38 C 120 22 108 14 92 14 C 80 14 72 22 72 32 C 72 44 86 48 96 48 C 110 48 120 38 124 28" />
              <path d="M 96 48 C 96 60 86 64 78 64" stroke-dasharray="3 3" />
              <ellipse cx="40" cy="96" rx="14" ry="6" />
              <path d="M 40 90 Q 40 96 40 102" opacity="0.55" stroke-dasharray="3 3" />
            </g>
          </svg>
          <h3>Klein bottle</h3>
          <p>One axis wraps with a flip. The other wraps normally.</p>
        </article>
        <article class="topology">
          <svg viewBox="0 0 160 120" aria-hidden="true">
            <g fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" stroke-linecap="round">
              <circle cx="80" cy="60" r="44" />
              <ellipse cx="80" cy="60" rx="44" ry="14" />
              <path d="M 80 16 Q 60 60 80 104" />
              <path d="M 80 16 Q 100 60 80 104" />
              <path d="M 80 16 Q 50 60 80 104" opacity="0.55" stroke-dasharray="3 3" />
              <path d="M 80 16 Q 110 60 80 104" opacity="0.55" stroke-dasharray="3 3" />
              <path d="M 36 60 Q 80 46 124 60" opacity="0.55" stroke-dasharray="3 3" />
              <path d="M 36 60 Q 80 74 124 60" opacity="0.55" stroke-dasharray="3 3" />
            </g>
          </svg>
          <h3>Sphere</h3>
          <p>Walk a great circle. There is no edge to fall off.</p>
        </article>
      </div>
    </section>

    <section aria-labelledby="controls">
      <h2 id="controls">Controls</h2>
      <ul class="rules">
        <li><strong>WASD</strong> to walk</li>
        <li><strong>MOUSE</strong> to look</li>
        <li><strong>HOLD SHIFT</strong> to sprint until your stamina runs out</li>
        <li><strong>LEFT CLICK</strong> to tag or unfreeze when you are close enough</li>
        <li><strong>ESC</strong> to release the cursor</li>
      </ul>
    </section>

    <footer>
      <p>
        Open source on <a href={githubUrl}>GitHub</a>. MIT licensed. Built by Sean Reid.
        Bug? <a href={`${githubUrl}/issues/new/choose`}>HONK at the issue tracker.</a>
      </p>
    </footer>

    <script type="module" define:vars={{ releasesApi }}>
      const COLORS = ['#ff3855', '#38c2ff', '#ffd400', '#ff8be0', '#ffffff'];

      function spawnConfetti() {
        const container = document.getElementById('confetti');
        if (!container) return;
        const count = window.matchMedia('(max-width: 600px)').matches ? 12 : 32;
        for (let i = 0; i < count; i += 1) {
          const piece = document.createElement('span');
          piece.style.left = `${Math.random() * 100}vw`;
          piece.style.background = COLORS[i % COLORS.length];
          piece.style.animationDuration = `${6 + Math.random() * 6}s`;
          piece.style.animationDelay = `${-Math.random() * 8}s`;
          piece.style.transform = `rotate(${Math.random() * 360}deg)`;
          container.appendChild(piece);
        }
      }

      function platform() {
        const ua = navigator.userAgent.toLowerCase();
        if (ua.includes('mac')) return 'macos';
        if (ua.includes('linux')) return 'linux';
        return 'windows';
      }

      function recommendCurrent() {
        const el = document.getElementById(`dl-${platform()}`);
        if (el) el.setAttribute('data-recommended', 'true');
      }

      async function hydrateFromLatestRelease() {
        try {
          const res = await fetch(releasesApi, {
            headers: { accept: 'application/vnd.github+json' },
          });
          if (!res.ok) return;
          const data = await res.json();
          const assets = Array.isArray(data.assets) ? data.assets : [];
          const updates = [
            { id: 'dl-windows', fileId: 'dl-windows-file', match: /windows|\.exe/i },
            { id: 'dl-macos', fileId: 'dl-macos-file', match: /mac|\.dmg|\.zip/i },
            { id: 'dl-linux', fileId: 'dl-linux-file', match: /linux|appimage/i },
          ];
          for (const { id, fileId, match } of updates) {
            const asset = assets.find((a) => match.test(a.name ?? ''));
            if (!asset) continue;
            const el = document.getElementById(id);
            const fileEl = document.getElementById(fileId);
            if (el && asset.browser_download_url) el.href = asset.browser_download_url;
            if (fileEl && asset.name) fileEl.textContent = asset.name;
          }
        } catch {
          /* keep static fallbacks */
        }
      }

      spawnConfetti();
      recommendCurrent();
      hydrateFromLatestRelease();
    </script>
  </body>
</html>
