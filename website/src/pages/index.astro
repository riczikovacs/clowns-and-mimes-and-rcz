---
const title = 'Clowns and Mimes, on Miscellaneous Topological Spaces... IN THE DARK';
const githubUrl = 'https://github.com/sean-reid/clowns-and-mimes';
const releasesApi = 'https://api.github.com/repos/sean-reid/clowns-and-mimes/releases/latest';
const baseRaw = import.meta.env.BASE_URL ?? '/';
const base = baseRaw.endsWith('/') ? baseRaw : `${baseRaw}/`;
const mimeAvatar = `${base}avatars/mime.png`;
const clownAvatar = `${base}avatars/clown.png`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    <title>{title}</title>
    <meta
      name="description"
      content="A team tag game played on a dimly lit labyrinth that wraps in unusual ways."
    />
    <meta property="og:title" content={title} />
    <meta
      property="og:description"
      content="Tag every opponent before they tag you. The arena might be a torus, a Möbius strip, or a Klein bottle."
    />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16'%3E%3Crect width='16' height='16' fill='%23c8102e'/%3E%3Ccircle cx='5' cy='8' r='3.4' fill='%23fff5d6'/%3E%3Ccircle cx='11' cy='8' r='3.4' fill='%230c0c0e'/%3E%3C/svg%3E"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Alfa+Slab+One&family=Patrick+Hand&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        color-scheme: dark;
        --paper: #fff5d6;
        --paper-shade: #f4e4ad;
        --ink: #0c0c0e;
        --red: #c8102e;
        --gold: #f4c430;
        --blue: #1a3a8a;
        --night: #1a0a14;
        --night-soft: #2a121f;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        font-family: 'Patrick Hand', 'Comic Sans MS', cursive;
        font-size: 1.15rem;
        line-height: 1.5;
        color: var(--ink);
        background-color: var(--night);
        background-image:
          repeating-linear-gradient(
            45deg,
            transparent 0 22px,
            rgba(255, 245, 214, 0.04) 22px 24px
          );
        overflow-x: hidden;
      }
      .page {
        max-width: 1040px;
        margin: 0 auto;
        padding: 2.5rem 1.25rem 5rem;
      }
      .poster {
        background: var(--paper);
        color: var(--ink);
        border: 4px solid var(--ink);
        border-radius: 14px;
        padding: 2rem 1.5rem 2.5rem;
        position: relative;
        box-shadow: 10px 10px 0 var(--red);
        transform: rotate(var(--tilt, 0deg));
        transition: transform 200ms ease;
      }
      .poster:nth-of-type(1) { --tilt: -0.6deg; }
      .poster:nth-of-type(2) { --tilt: 0.8deg; }
      .poster:nth-of-type(3) { --tilt: -0.5deg; }
      .poster:nth-of-type(4) { --tilt: 0.7deg; }
      .poster:nth-of-type(5) { --tilt: -0.4deg; }
      .poster + .poster { margin-top: 2rem; }
      .poster::before,
      .poster::after {
        content: '';
        position: absolute;
        width: 12px;
        height: 12px;
        background: var(--ink);
        border-radius: 50%;
      }
      .poster::before { top: 10px; left: 10px; }
      .poster::after { top: 10px; right: 10px; }
      .stripe-banner {
        background:
          repeating-linear-gradient(
            90deg,
            var(--red) 0 24px,
            var(--paper) 24px 48px
          );
        height: 18px;
        margin: -2rem -1.5rem 1.5rem;
        border-bottom: 4px solid var(--ink);
        border-radius: 10px 10px 0 0;
      }
      .heads {
        display: flex;
        justify-content: center;
        gap: 1.6rem;
        margin: 0 0 1.2rem;
      }
      .head {
        width: clamp(110px, 18vw, 170px);
        height: clamp(145px, 24vw, 220px);
        object-fit: cover;
        object-position: center 30%;
        border-radius: 50%;
        background: var(--paper-shade);
        display: block;
      }
      .head.mime {
        border: 6px solid var(--ink);
        box-shadow: 6px 6px 0 var(--blue);
        animation: bobLeft 3.6s ease-in-out infinite;
      }
      .head.clown {
        border: 6px solid var(--ink);
        box-shadow: 6px 6px 0 var(--red);
        animation: bobRight 3.6s ease-in-out infinite;
      }
      h1 {
        font-family: 'Alfa Slab One', 'Impact', serif;
        font-weight: 400;
        text-align: center;
        font-size: clamp(2rem, 5.5vw, 3.6rem);
        line-height: 1.05;
        margin: 0.5rem 0 0.4rem;
        color: var(--red);
        letter-spacing: 0.01em;
        animation: titleWiggle 5s ease-in-out infinite;
        transform-origin: center;
      }
      h1 .bounce {
        display: inline-block;
        color: var(--gold);
        animation: bounce 1.6s ease-in-out infinite;
      }
      h1 .small {
        display: block;
        font-size: clamp(0.95rem, 2vw, 1.4rem);
        color: var(--ink);
        letter-spacing: 0.18em;
        margin-top: 0.4rem;
        font-family: 'Alfa Slab One', serif;
      }
      h1 .dark {
        color: var(--ink);
      }
      h2 {
        font-family: 'Alfa Slab One', serif;
        font-weight: 400;
        font-size: clamp(1.6rem, 3.5vw, 2.4rem);
        color: var(--ink);
        margin: 0 0 1rem;
        text-align: center;
        position: relative;
      }
      h2::before, h2::after {
        content: '✦';
        color: var(--red);
        margin: 0 0.6rem;
        font-size: 0.7em;
        vertical-align: 0.2em;
      }
      .downloads {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
      }
      .download {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
        padding: 1rem 1.1rem;
        background: var(--paper-shade);
        border: 3px solid var(--ink);
        border-radius: 10px;
        text-decoration: none;
        color: var(--ink);
        transition: transform 120ms ease, box-shadow 120ms ease;
        box-shadow: 4px 4px 0 var(--ink);
      }
      .download:hover {
        transform: translate(-2px, -2px);
        box-shadow: 6px 6px 0 var(--red);
      }
      .download[data-recommended='true'] {
        background: var(--gold);
      }
      .download[data-recommended='true']::before {
        content: 'YOUR OS';
        position: absolute;
        top: -10px;
        right: 10px;
        background: var(--red);
        color: var(--paper);
        font-family: 'Alfa Slab One', serif;
        font-size: 0.7rem;
        padding: 0.1rem 0.4rem;
        border: 2px solid var(--ink);
        border-radius: 4px;
      }
      .download .platform {
        font-family: 'Alfa Slab One', serif;
        font-size: 1.2rem;
        letter-spacing: 0.04em;
      }
      .download .file { font-size: 1rem; color: rgba(12, 12, 14, 0.7); }
      .rules {
        margin: 0;
        padding: 0 0 0 1.5rem;
        font-size: 1.2rem;
      }
      .rules li { padding: 0.2rem 0; }
      .rules li::marker { color: var(--red); font-weight: 700; }
      .rules strong {
        background: var(--gold);
        padding: 0 0.4rem;
        border: 2px solid var(--ink);
        border-radius: 4px;
        font-family: 'Alfa Slab One', serif;
        font-weight: 400;
        font-size: 0.9em;
      }
      .topologies {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 1rem;
      }
      .topology {
        padding: 1rem;
        background: var(--paper-shade);
        border: 3px solid var(--ink);
        border-radius: 10px;
        box-shadow: 4px 4px 0 var(--ink);
        transform: rotate(var(--card-tilt, 0deg));
        transition: transform 200ms ease, box-shadow 200ms ease;
      }
      .topology:nth-child(1) { --card-tilt: -1.4deg; }
      .topology:nth-child(2) { --card-tilt: 1.2deg; }
      .topology:nth-child(3) { --card-tilt: -1deg; }
      .topology:nth-child(4) { --card-tilt: 1.5deg; }
      .topology:hover {
        transform: rotate(0deg) scale(1.03);
        box-shadow: 6px 6px 0 var(--red);
      }
      .topology svg {
        width: 100%;
        height: 110px;
        display: block;
        margin-bottom: 0.6rem;
        color: var(--ink);
      }
      .topology h3 {
        font-family: 'Alfa Slab One', serif;
        font-weight: 400;
        margin: 0 0 0.25rem;
        font-size: 1.15rem;
        color: var(--red);
      }
      .topology p { margin: 0; font-size: 1rem; color: var(--ink); }
      .footer-line {
        text-align: center;
        color: var(--paper);
        font-size: 1rem;
        margin: 2.5rem auto 0;
        max-width: 60ch;
      }
      .footer-line a { color: var(--gold); }
      @keyframes titleWiggle {
        0%, 100% { transform: rotate(-1.5deg); }
        25% { transform: rotate(1.5deg) translateY(-2px); }
        50% { transform: rotate(-2deg); }
        75% { transform: rotate(1deg) translateY(1px); }
      }
      @keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-8px) rotate(6deg); }
      }
      @keyframes bobLeft {
        0%, 100% { transform: rotate(-3deg) translateY(0); }
        50% { transform: rotate(-6deg) translateY(-6px); }
      }
      @keyframes bobRight {
        0%, 100% { transform: rotate(3deg) translateY(0); }
        50% { transform: rotate(7deg) translateY(-7px); }
      }
      @keyframes fall {
        from { transform: translateY(-10vh) rotate(0deg); }
        to { transform: translateY(110vh) rotate(720deg); }
      }
      .confetti {
        position: fixed;
        inset: 0;
        pointer-events: none;
        z-index: -1;
      }
      .confetti span {
        position: absolute;
        width: 9px;
        height: 14px;
        opacity: 0.75;
        animation: fall linear infinite;
      }
      @media (prefers-reduced-motion: reduce) {
        h1, .head.mime, .head.clown, .topology, .poster, h1 .bounce, .confetti span {
          animation: none !important;
        }
        .poster, .topology { transform: none !important; }
        .head.mime { transform: rotate(-3deg); }
        .head.clown { transform: rotate(3deg); }
      }
      @media (max-width: 520px) {
        .heads { flex-wrap: wrap; }
      }
    </style>
  </head>
  <body>
    <div class="confetti" aria-hidden="true" id="confetti"></div>
    <div class="page">
      <article class="poster">
        <div class="stripe-banner" aria-hidden="true"></div>
        <div class="heads">
          <img class="head mime" src={mimeAvatar} alt="Mime portrait" width="170" height="220" />
          <img class="head clown" src={clownAvatar} alt="Clown portrait" width="170" height="220" />
        </div>
        <h1>
          <span class="dark">CLOWNS</span> &amp; <span class="dark">MIMES</span>
          <span class="bounce">!!</span>
          <span class="small">ON MISCELLANEOUS TOPOLOGICAL SPACES</span>
          <span class="small dark">...IN THE DARK</span>
        </h1>
      </article>

      <article class="poster">
        <h2>Download</h2>
        <div class="downloads">
          <a id="dl-windows" class="download" href={`${githubUrl}/releases/latest`}>
            <span class="platform">Windows</span>
            <span class="file" id="dl-windows-file">latest .exe</span>
          </a>
          <a id="dl-macos" class="download" href={`${githubUrl}/releases/latest`}>
            <span class="platform">macOS</span>
            <span class="file" id="dl-macos-file">latest .dmg</span>
          </a>
          <a id="dl-linux" class="download" href={`${githubUrl}/releases/latest`}>
            <span class="platform">Linux</span>
            <span class="file" id="dl-linux-file">latest AppImage</span>
          </a>
        </div>
      </article>

      <article class="poster">
        <h2>How to play</h2>
        <ol class="rules">
          <li>Pick <strong>HOST</strong>, <strong>CODE</strong>, or <strong>STRANGERS</strong> from the main menu.</li>
          <li>Everyone spawns in the center square. Thirty seconds to wander before tags count.</li>
          <li>Turns alternate between the mime team and the clown team. Tag opponents during your turn to freeze them.</li>
          <li>Touch a frozen teammate to thaw them.</li>
          <li>Win when every player on the other team is frozen.</li>
        </ol>
      </article>

      <article class="poster">
        <h2>Topologies</h2>
        <div class="topologies">
          <article class="topology">
            <svg viewBox="0 0 160 120" aria-hidden="true">
              <g fill="none" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round" stroke-linecap="round">
                <rect x="22" y="22" width="116" height="76" rx="6" />
                <line x1="22" y1="46" x2="138" y2="46" opacity="0.55" />
                <line x1="22" y1="70" x2="138" y2="70" opacity="0.55" />
                <line x1="60" y1="22" x2="60" y2="98" opacity="0.55" />
                <line x1="100" y1="22" x2="100" y2="98" opacity="0.55" />
              </g>
            </svg>
            <h3>Plane</h3>
            <p>Finite square arena. Hard walls at the edges.</p>
          </article>
          <article class="topology">
            <svg viewBox="0 0 160 120" aria-hidden="true">
              <g fill="none" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round" stroke-linecap="round">
                <ellipse cx="80" cy="60" rx="60" ry="32" />
                <path d="M 32 60 Q 80 36 128 60" />
                <path d="M 40 60 Q 80 78 120 60" stroke-dasharray="4 4" />
                <ellipse cx="80" cy="60" rx="20" ry="8" />
              </g>
            </svg>
            <h3>Torus</h3>
            <p>Both axes wrap. Walk off one side, come out the opposite.</p>
          </article>
          <article class="topology">
            <svg viewBox="0 0 160 120" aria-hidden="true">
              <g fill="none" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round" stroke-linecap="round">
                <!-- Möbius strip fundamental polygon: a wide rectangle whose
                     left and right edges glue with a z-flip; top and bottom
                     are hard walls (the strip's single boundary loop). -->
                <rect x="20" y="36" width="120" height="48" rx="4" />
                <!-- Top edge: solid thick line (hard wall, no arrows) -->
                <line x1="20" y1="36" x2="140" y2="36" stroke-width="3.6" />
                <!-- Bottom edge: solid thick line (hard wall, no arrows) -->
                <line x1="20" y1="84" x2="140" y2="84" stroke-width="3.6" />
                <!-- Left edge: double chevron pointing up (identification) -->
                <line x1="20" y1="74" x2="20" y2="46" stroke-width="2.6" />
                <path d="M 14 54 L 20 46 L 26 54" stroke-width="2.6" />
                <path d="M 14 62 L 20 54 L 26 62" stroke-width="2.6" />
                <!-- Right edge: double chevron pointing DOWN (opposite = the z-flip) -->
                <line x1="140" y1="46" x2="140" y2="74" stroke-width="2.6" />
                <path d="M 134 66 L 140 74 L 146 66" stroke-width="2.6" />
                <path d="M 134 58 L 140 66 L 146 58" stroke-width="2.6" />
              </g>
            </svg>
            <h3>Möbius strip</h3>
            <p>One axis wraps with a flip. The other has hard walls at top and bottom.</p>
          </article>
          <article class="topology">
            <svg viewBox="0 0 160 120" aria-hidden="true">
              <g fill="none" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round" stroke-linecap="round">
                <!-- Fundamental polygon: a square whose edges are identified -->
                <rect x="36" y="22" width="88" height="76" rx="4" />
                <!-- Top edge: single arrow rightward -->
                <line x1="60" y1="22" x2="100" y2="22" stroke-width="2.6" />
                <path d="M 92 16 L 100 22 L 92 28" stroke-width="2.6" />
                <!-- Bottom edge: matching single arrow rightward (top/bottom identified) -->
                <line x1="60" y1="98" x2="100" y2="98" stroke-width="2.6" />
                <path d="M 92 92 L 100 98 L 92 104" stroke-width="2.6" />
                <!-- Left edge: double chevron pointing up -->
                <line x1="36" y1="78" x2="36" y2="42" stroke-width="2.6" />
                <path d="M 30 50 L 36 42 L 42 50" stroke-width="2.6" />
                <path d="M 30 58 L 36 50 L 42 58" stroke-width="2.6" />
                <!-- Right edge: double chevron pointing DOWN (opposite = the flip) -->
                <line x1="124" y1="42" x2="124" y2="78" stroke-width="2.6" />
                <path d="M 118 70 L 124 78 L 130 70" stroke-width="2.6" />
                <path d="M 118 62 L 124 70 L 130 62" stroke-width="2.6" />
              </g>
            </svg>
            <h3>Klein bottle</h3>
            <p>Both axes wrap; the x seam flips the vertical.</p>
          </article>
        </div>
      </article>

      <article class="poster">
        <h2>Controls</h2>
        <ul class="rules">
          <li><strong>WASD</strong> to walk</li>
          <li><strong>MOUSE</strong> to look</li>
          <li><strong>HOLD SHIFT</strong> to sprint until your stamina runs out</li>
          <li><strong>SPACE</strong> to jump over (or out of reach of) another player</li>
          <li><strong>RUN INTO</strong> an opponent to tag, or a frozen teammate to thaw</li>
          <li><strong>ESC</strong> to open the menu (the match keeps playing)</li>
        </ul>
      </article>

      <p class="footer-line">
        Open source on <a href={githubUrl}>GitHub</a>. Built by Sean Reid.
      </p>
    </div>

    <script type="module" define:vars={{ releasesApi }}>
      const COLORS = ['#c8102e', '#f4c430', '#1a3a8a', '#fff5d6', '#0c0c0e'];
      function spawnConfetti() {
        const container = document.getElementById('confetti');
        if (!container) return;
        const count = window.matchMedia('(max-width: 600px)').matches ? 14 : 36;
        for (let i = 0; i < count; i += 1) {
          const piece = document.createElement('span');
          piece.style.left = `${Math.random() * 100}vw`;
          piece.style.background = COLORS[i % COLORS.length];
          piece.style.animationDuration = `${7 + Math.random() * 6}s`;
          piece.style.animationDelay = `${-Math.random() * 9}s`;
          piece.style.transform = `rotate(${Math.random() * 360}deg)`;
          container.appendChild(piece);
        }
      }

      function platform() {
        const ua = navigator.userAgent.toLowerCase();
        if (ua.includes('mac')) return 'macos';
        if (ua.includes('linux')) return 'linux';
        return 'windows';
      }
      function recommendCurrent() {
        const el = document.getElementById(`dl-${platform()}`);
        if (el) el.setAttribute('data-recommended', 'true');
      }
      async function hydrateFromLatestRelease() {
        try {
          const res = await fetch(releasesApi, {
            headers: { accept: 'application/vnd.github+json' },
          });
          if (!res.ok) return;
          const data = await res.json();
          const assets = Array.isArray(data.assets) ? data.assets : [];
          // macOS prefers .dmg over .zip; older v0.1.x releases shipped a .zip
          // fallback, v0.2.0+ ships a notarized .dmg only. The two-pass match
          // picks the .dmg whenever it exists.
          const updates = [
            { id: 'dl-windows', fileId: 'dl-windows-file', matches: [/\.exe$/i, /windows/i] },
            { id: 'dl-macos', fileId: 'dl-macos-file', matches: [/\.dmg$/i, /mac.*\.zip$/i] },
            { id: 'dl-linux', fileId: 'dl-linux-file', matches: [/linux|appimage/i] },
          ];
          for (const { id, fileId, matches } of updates) {
            let asset;
            for (const match of matches) {
              asset = assets.find((a) => match.test(a.name ?? ''));
              if (asset) break;
            }
            if (!asset) continue;
            const el = document.getElementById(id);
            const fileEl = document.getElementById(fileId);
            if (el && asset.browser_download_url) el.href = asset.browser_download_url;
            if (fileEl && asset.name) fileEl.textContent = asset.name;
          }
        } catch {
          /* keep static fallbacks */
        }
      }
      spawnConfetti();
      recommendCurrent();
      hydrateFromLatestRelease();
    </script>
  </body>
</html>
