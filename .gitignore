.wrangler/
wrangler.toml.bak

# Godot: track .import sidecars and .uid files (Godot 4 recommends committing
# them so import settings and resource UIDs are stable across machines).
# Only the derived caches and build outputs are ignored.
game/.godot/
game/.import/
game/builds/
game/*.translation

# Game export artifacts
out/
exports/
*.pck
*.exe
*.dmg
*.AppImage
*.deb
*.zip
*.tar.gz

# Logs and temp
*.log
.cache/
tmp/
coverage/
playwright-report/
test-results/

# Local secrets
.env
.env.local
.env.*.local

# Agent tooling artifacts that must never be tracked
.claude/
CLAUDE.md
.aider*
.cursor/
